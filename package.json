{
  "name": "qa-agent",
  "version": "0.1.0",
  "description": "AI 质量医生 - 能诊断、能开药、能验证疗效",
  "keywords": [
    "ai",
    "testing",
    "e2e",
    "accessibility",
    "quality",
    "cli",
    "playwright",
    "bun"
  ],
  "author": "Your Name",
  "license": "MIT",
  "type": "module",
  "main": "src/cli/index.ts",
  "types": "src/types/index.ts",
  "bin": {
    "qa-agent": "./src/cli/index.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "build": "bun build src/cli/index.ts --compile --outfile dist/qa-agent",
    "build:windows": "bun build src/cli/index.ts --compile --target=bun-windows-x64 --outfile dist/qa-agent.exe",
    "build:linux": "bun build src/cli/index.ts --compile --target=bun-linux-x64 --outfile dist/qa-agent",
    "build:mac": "bun build src/cli/index.ts --compile --target=bun-darwin-x64 --outfile dist/qa-agent",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "link": "bun link"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@playwright/test": "^1.43.0",
    "axe-core": "^4.9.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "glob": "^10.3.0",
    "hono": "^4.12.14",
    "inquirer": "^9.2.0",
    "ora": "^8.0.0",
    "playwright": "^1.43.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/inquirer": "^9.0.0",
    "@types/node": "^20.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.10",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.4.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/qa-agent.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/qa-agent/issues"
  },
  "homepage": "https://github.com/your-org/qa-agent#readme"
}
